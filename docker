services:
  database:
    image: mysql:8.4
    environment:
      MYSQL_ROOT_PASSWORD: 2002
      MYSQL_DATABASE: skillpulse

  backend:
    image: skillpulse/go-backend:latest
    ports:
      - "8080:8080" 

  frontend:
    image: skillpulse/nginx-frontend:latest
    ports:
      - "8080:8080" 
    depends_on:
      - backend               
